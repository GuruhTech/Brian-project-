# Brisa Motors environment example
# Copy this file to .env and fill in your real credentials.
# These are the variables server.js actually reads (process.env.*).

PORT=5000
JWT_SECRET=your_jwt_secret_here

# Public base URL of your deployed app (used to build password-reset links)
APP_URL=https://your-deployed-domain.com

# Supabase (Settings -> API in your Supabase project)
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# Paystack (Settings -> API Keys & Webhooks in your Paystack Dashboard)
# Use the sk_test_... key while testing, sk_live_... once you go live.
PAYSTACK_SECRET_KEY=your_paystack_secret_key_here
