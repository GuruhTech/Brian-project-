# Brisa Motors environment example
# Copy this file to .env and fill in your real credentials.

PORT=5000
JWT_SECRET=your_jwt_secret_here

# M-Pesa Daraja / STK Push settings
MPESA_ENV=sandbox
MPESA_SHORTCODE=174379
MPESA_PASSKEY=your_mpesa_passkey_here
MPESA_CONSUMER_KEY=your_mpesa_consumer_key_here
MPESA_CONSUMER_SECRET=your_mpesa_consumer_secret_here
MPESA_CALLBACK_URL=http://localhost:5000/api/payments/mpesa/callback
